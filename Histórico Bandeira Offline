      "2024": {"1":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"2":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"3":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"4":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"5":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"6":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"7":{"n":"Amarela","c":"#FFD54F","v":"R$ 1,89 por MWh"},"8":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"9":{"n":"Vermelho 1","c":"#E53935","v":"R$ 4,46 por MWh"},"10":{"n":"Vermelho 2","c":"#B71C1C","v":"R$ 7,88 por MWh"},"11":{"n":"Amarelo","c":"#FFD54F","v":"R$ 1,89 por MWh"},"12":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"}},
      "2023": {"1":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"2":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"3":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"4":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"5":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"6":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"7":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"8":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"9":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"10":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"11":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"12":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"}},
