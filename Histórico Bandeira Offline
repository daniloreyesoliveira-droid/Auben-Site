<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Histórico de Bandeiras | Aubeny</title>
    <style>
        body { font-family: 'Inter', system-ui, sans-serif; margin: 0; min-height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; background: linear-gradient(135deg, #2e3192, #d4145a, #f7941e); padding: 40px 20px; box-sizing: border-box; }
        .logo-box { margin-bottom: 20px; text-align: center; }
        .logo-box img { max-width: 150px; height: auto; }
        .container { width: 100%; max-width: 450px; background: #fff; padding: 30px; border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.25); text-align: center; margin-bottom: 20px; box-sizing: border-box; }
        h1 { font-size: 18px; color: #0f172a; margin-bottom: 5px; }
        h2 { font-size: 16px; color: #0f172a; margin: 0 0 20px 0; text-align: center; }
        p { color: #64748b; font-size: 13px; margin: 0 0 20px 0; }
        .controls { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        select, button { padding: 12px; border-radius: 10px; border: 1.5px solid #e2e8f0; font-size: 14px; }
        button { grid-column: span 2; background: #0f172a; color: #fff; font-weight: 600; cursor: pointer; border: none; transition: 0.3s; }
        button:hover { background: #334155; }
        #result { margin-top: 20px; padding: 15px; border-radius: 12px; display: none; border-left: 5px solid #ccc; background: #f8fafc; text-align: left; }
        .calc-box { margin-top: 15px; padding-top: 15px; border-top: 1px solid #cbd5e1; }
        .calc-box p { margin: 0 0 10px 0; font-size: 12px; color: #0f172a; font-weight: 600; }
        .calc-input { width: 100%; box-sizing: border-box; padding: 10px; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 13px; outline: none; }
        .calc-res { margin-top: 10px; font-size: 14px; font-weight: 600; color: #d4145a; min-height: 20px; }
        .info-container { padding: 0; }
        .acc-head { display: flex; justify-content: space-between; align-items: center; cursor: pointer; padding: 20px 30px; font-weight: 600; font-size: 14px; color: #0f172a; }
        .acc-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; }
        .acc-inner { padding: 0 30px 30px 30px; color: #64748b; font-size: 13px; line-height: 1.6; text-align: left; }
        .acc-inner p:last-child { margin-bottom: 0; }
        #icon { transition: transform 0.3s; }
        .table-container { max-width: 600px; padding: 30px 20px; }
        .table-wrapper { overflow-x: auto; margin-bottom: 20px; padding-top: 10px; }
        table { width: 100%; border-collapse: collapse; text-align: center; font-size: 12px; min-width: 400px; }
        th, td { padding: 10px 5px; border: 1px solid #e2e8f0; vertical-align: middle; }
        th, td:first-child { background: #f8fafc; font-weight: 600; color: #475569; }
        td:first-child { text-align: left; padding-left: 15px; }
        .flag { width: 20px; height: 20px; display: block; margin: 0 auto; cursor: pointer; }
        .tooltip { position: relative; display: inline-flex; justify-content: center; align-items: center; }
        .tooltip::after, .tooltip::before { position: absolute; left: 50%; transform: translateX(-50%); opacity: 0; visibility: hidden; pointer-events: none; transition: opacity 0.2s ease, visibility 0s linear 0.2s; z-index: 10; }
        .tooltip::after { content: attr(data-tip); bottom: 130%; background: #0f172a; color: #fff; padding: 6px 10px; border-radius: 6px; font-size: 11px; white-space: nowrap; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .tooltip::before { content: ""; bottom: 100%; border-width: 5px; border-style: solid; border-color: #0f172a transparent transparent transparent; }
        .tooltip:hover::after, .tooltip:hover::before { opacity: 1; visibility: visible; transition: opacity 0.2s ease 1s, visibility 0s linear 1s; }
        .legend { display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; font-size: 11px; color: #64748b; }
        .leg-item { display: flex; align-items: center; gap: 5px; }
        .leg-icon { width: 14px; height: 14px; }
    </style>
</head>
<body>
<div class="logo-box">
    <img src="https://raw.githubusercontent.com/daniloreyesoliveira-droid/Auben-Site/main/Auben%20Removal.png" alt="Logo Aubeny">
</div>

    <div class="container">
        <h1>Histórico de Bandeiras</h1>
        <p>Consulte o custo extra por MWh de cada período.</p>
        <div class="controls">
            <select id="ano" onchange="updMes()"><option value="">Ano</option></select>
            <select id="mes"><option value="">Mês</option></select>
            <button onclick="consultar()">Consultar Histórico</button>
        </div>
        <div id="result"></div>
    </div>

    <div class="container info-container">
        <div class="acc-head" onclick="toggleAcc()">
            <span>Entenda as Bandeiras Tarifárias</span>
            <span id="icon">▼</span>
        </div>
        <div id="acc-content" class="acc-content">
            <div class="acc-inner">
                <p>As bandeiras tarifárias sinalizam cobrança adicional na conta de luz por MWh consumido, definidas mensalmente pela ANEEL.</p>
                <p>🟢 <strong>Verde:</strong> sem adicional.<br>🟡 <strong>Amarela:</strong> pequeno acréscimo.<br>🔴 <strong>Vermelha 1 e 2:</strong> acréscimos maiores.</p>
                <p><strong>Importante:</strong> Clientes do Mercado Livre de Energia não sofrem alterações das bandeiras tarifárias.</p>
            </div>
        </div>
    </div>

    <div class="container table-container">
        <h2>Visão Geral (2021 - 2026)</h2>
        <div class="table-wrapper">
            <table>
                <thead><tr><th>Mês</th><th>2026</th><th>2025</th><th>2024</th><th>2023</th><th>2022</th><th>2021</th></tr></thead>
                <tbody id="tabBody"></tbody>
            </table>
        </div>
        <div class="legend" id="legend"></div>
    </div>

<script>
    const db = {
      "2026": {"1":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"2":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"3":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"4":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"5":{"n":"Amarelo","c":"#FFD54F","v":"R$ 18,85 por MWh"},"6":{"n":"Amarelo","c":"#FFD54F","v":"R$ 18,85 por MWh"},"7":{"n":"Amarelo","c":"#FFD54F","v":"R$ 18,85 por MWh"}},
      "2025": {"1":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"2":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"3":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"4":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"5":{"n":"Amarelo","c":"#FFD54F","v":"R$ 18,85 por MWh"},"6":{"n":"Vermelho 1","c":"#E53935","v":"R$ 44,63 por MWh"},"7":{"n":"Vermelho 1","c":"#E53935","v":"R$ 44,63 por MWh"},"8":{"n":"Vermelho 2","c":"#B71C1C","v":"R$ 78,77 por MWh"},"9":{"n":"Vermelho 1","c":"#E53935","v":"R$ 44,63 por MWh"},"10":{"n":"Vermelho 1","c":"#E53935","v":"R$ 44,63 por MWh"},"11":{"n":"Vermelho 1","c":"#E53935","v":"R$ 44,63 por MWh"},"12":{"n":"Amarelo","c":"#FFD54F","v":"R$ 18,85 por MWh"}},
      "2024": {"1":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"2":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"3":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"4":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"5":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"6":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"7":{"n":"Amarela","c":"#FFD54F","v":"R$ 1,89 por MWh"},"8":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"9":{"n":"Vermelho 1","c":"#E53935","v":"R$ 4,46 por MWh"},"10":{"n":"Vermelho 2","c":"#B71C1C","v":"R$ 7,88 por MWh"},"11":{"n":"Amarelo","c":"#FFD54F","v":"R$ 1,89 por MWh"},"12":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"}},
      "2023": {"1":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"2":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"3":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"4":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"5":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"6":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"7":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"8":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"9":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"10":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"11":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"12":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"}},
      "2022": {"1":{"n":"Escassez","c":"#0d47a1","v":"R$ 14,20 por MWh"},"2":{"n":"Escassez","c":"#0d47a1","v":"R$ 14,20 por MWh"},"3":{"n":"Escassez","c":"#0d47a1","v":"R$ 1420 por MWh"},"4":{"n":"Escassez","c":"#0d47a1","v":"R$ 14,20 por MWh"},"5":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"6":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"7":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"8":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"9":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"10":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"11":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"},"12":{"n":"Verde","c":"#28a745","v":"Sem cobrança adicional"}},
      "2021": {"1":{"n":"Amarelo","c":"#FFD54F","v":"R$ 13,43 por MWh"},"2":{"n":"Amarelo","c":"#FFD54F","v":"R$ 13,43 por MWh"},"3":{"n":"Amarelo","c":"#FFD54F","v":"R$ 13,43 por MWh"},"4":{"n":"Amarelo","c":"#FFD54F","v":"R$ 13,43 por MWh"},"5":{"n":"Vermelho 1","c":"#E53935","v":"R$ 41,69 por MWh"},"6":{"n":"Vermelho 2","c":"#B71C1C","v":"R$ 94,92 por MWh"},"7":{"n":"Vermelho 2","c":"#B71C1C","v":"R$ 94,92 por MWh"},"8":{"n":"Vermelho 2","c":"#B71C1C","v":"R$ 94,92 por MWh"},"9":{"n":"Escassez","c":"#0d47a1","v":"R$ 142,00 por MWh"},"10":{"n":"Escassez","c":"#0d47a1","v":"R$ 142,00 por MWh"},"11":{"n":"Escassez","c":"#0d47a1","v":"R$ 142,00 por MWh"},"12":{"n":"Escassez","c":"#0d47a1","v":"R$ 142,00 por MWh"}}
    };

    let curRate = 0;
    const meses = ["Jan", "Fev", "Mar", "Abr", "Mai", "Jun", "Jul", "Ago", "Set", "Out", "Nov", "Dez"];
    
    // Helper para gerar o SVG da bandeira
    const getSvg = (cor, cls) => `<svg class="${cls}" viewBox="0 0 24 24" fill="${cor}"><path d="M14.4 6L14 4H5v17h2v-7h5.6l.4 2h7V6z"/></svg>`;

    // Init Select Ano
    const selAno = document.getElementById('ano');
    Object.keys(db).forEach(a => selAno.innerHTML += `<option value="${a}">${a}</option>`);

    function updMes() {
        const selMes = document.getElementById('mes');
        selMes.innerHTML = '<option value="">Mês</option>';
        if(selAno.value) Object.keys(db[selAno.value]).forEach(m => selMes.innerHTML += `<option value="${m}">${meses[m-1]}</option>`);
    }

    function consultar() {
        const a = selAno.value, m = document.getElementById('mes').value, res = document.getElementById('result');
        if (!a || !m) return alert("Selecione ano e mês.");
        
        const i = db[a][m];
        res.style.display = 'block'; res.style.background = i.c + "10"; res.style.borderLeftColor = i.c;
        
        let html = `<strong style="color:${i.c}">${i.n}</strong><br>Custo: ${i.v}`;
        if (!i.v.includes("Sem")) {
            curRate = parseFloat(i.v.replace("R$ ", "").replace(" por MWh", "").replace(",", "."));
            html += `<div class="calc-box"><p>Consumo mensal (kWh)?</p><input type="number" id="kwh" class="calc-input" placeholder="Ex: 500" oninput="calc()"><div id="res-calc" class="calc-res"></div></div>`;
        } else curRate = 0;
        res.innerHTML = html;
    }

    function calc() {
        const k = parseFloat(document.getElementById('kwh').value);
        document.getElementById('res-calc').innerHTML = (k > 0) ? `Adicional: ${((k/1000)*curRate).toLocaleString('pt-BR',{style:'currency',currency:'BRL'})}` : '';
    }

    function toggleAcc() {
        const c = document.getElementById('acc-content'), i = document.getElementById('icon');
        const isClosed = !c.style.maxHeight || c.style.maxHeight === "0px";
        c.style.maxHeight = isClosed ? c.scrollHeight + "px" : "0px";
        i.style.transform = isClosed ? "rotate(180deg)" : "rotate(0deg)";
    }

    function initTable() {
        const anos = ["2026", "2025", "2024", "2023", "2022", "2021"];
        let html = '';
        for (let m = 1; m <= 12; m++) {
            html += `<tr><td>${meses[m-1]}</td>` + anos.map(a => {
                const i = db[a] && db[a][m];
                return `<td>${i && i.n !== "nan" ? `<div class="tooltip" data-tip="${i.v}">${getSvg(i.c, 'flag')}</div>` : `<span style="color:#cbd5e1">-</span>`}</td>`;
            }).join('') + `</tr>`;
        }
        document.getElementById('tabBody').innerHTML = html;
        
        // Init Legend
        const legData = [["#28a745","Verde"],["#FFD54F","Amarela"],["#E53935","Vermelha 1"],["#B71C1C","Vermelha 2"],["#0d47a1","Escassez"]];
        document.getElementById('legend').innerHTML = legData.map(l => `<div class="leg-item">${getSvg(l[0], 'leg-icon')} ${l[1]}</div>`).join('');
    }
    initTable();
</script>
</body>
</html>
