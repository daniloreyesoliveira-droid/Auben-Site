<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Histórico de Bandeiras | Auben</title>
    <style>
        body { 
            font-family: 'Inter', system-ui, sans-serif; 
            margin: 0; min-height: 100vh;
            display: flex; flex-direction: column;
            justify-content: center; align-items: center;
            background: linear-gradient(135deg, #2e3192, #d4145a, #f7941e);
            padding: 20px;
        }
        .logo-box { margin-bottom: 20px; }
        .logo-box img { max-width: 150px; height: auto; }
        
        .container { 
            width: 100%; max-width: 400px; 
            background: white; padding: 30px; 
            border-radius: 24px; 
            box-shadow: 0 20px 40px rgba(0,0,0,0.25);
            text-align: center;
        }
        
        h1 { font-size: 18px; color: #0f172a; margin-bottom: 5px; }
        p { color: #64748b; font-size: 13px; margin-bottom: 20px; }
        
        .controls { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        select, button { padding: 12px; border-radius: 10px; border: 1.5px solid #e2e8f0; font-size: 14px; }
        button { grid-column: span 2; background: #0f172a; color: white; font-weight: 600; cursor: pointer; border: none; }
        button:hover { background: #334155; }
        
        #result { margin-top: 20px; padding: 15px; border-radius: 12px; display: none; border-left: 5px solid #ccc; background: #f8fafc; text-align: left; }
    </style>
</head>
<body>

    <div class="logo-box">
 <img src="data:image/png;base64," alt="" width="500" height="500" />
    </div>

    <div class="container">
        <h1>Histórico de Bandeiras</h1>
        <p>Consulte o custo extra por MWh de cada período.</p>
        
        <div class="controls">
            <select id="ano" onchange="updateMonths()"><option value="">Ano</option></select>
            <select id="mes"><option value="">Mês</option></select>
            <button onclick="consultar()">Consultar Histórico</button>
        </div>
        <div id="result"></div>
    </div>

<script>
    const db = {
      "2026": { "1": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "2": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "4": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "5": {"nome": "Amarelo", "cor": "#FFD54F", "valor": "R$ 1,89 por MWh"}, "6": {"nome": "Amarelo", "cor": "#FFD54F", "valor": "R$ 1,89 por MWh"}, "7": {"nome": "Amarelo", "cor": "#FFD54F", "valor": "R$ 1,89 por MWh"}},
      "2025": { "1": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "2": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "4": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "5": {"nome": "Amarelo", "cor": "#FFD54F", "valor": "R$ 1,89 por MWh"}, "6": {"nome": "Vermelho 1", "cor": "#E53935", "valor": "R$ 4,46 por MWh"}, "7": {"nome": "Vermelho 1", "cor": "#E53935", "valor": "R$ 4,46 por MWh"}, "8": {"nome": "Vermelho 2 ", "cor": "#B71C1C", "valor": "R$ 7,88 por MWh"}, "9": {"nome": "Vermelho 1", "cor": "#E53935", "valor": "R$ 4,46 por MWh"}, "10": {"nome": "Vermelho 1", "cor": "#E53935", "valor": "R$ 4,46 por MWh"}, "11": {"nome": "Vermelho 1", "cor": "#E53935", "valor": "R$ 4,46 por MWh"}, "12": {"nome": "Amarelo", "cor": "#FFD54F", "valor": "R$ 1,89 por MWh"}},
      "2024": { "1": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "2": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "4": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "5": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "6": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "7": {"nome": "Amarela", "cor": "#FFD54F", "valor": "R$ 1,89 por MWh"}, "8": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "9": {"nome": "Vermelho 1", "cor": "#E53935", "valor": "R$ 4,46 por MWh"}, "10": {"nome": "Vermelho 2", "cor": "#B71C1C", "valor": "R$ 7,88 por MWh"}, "11": {"nome": "Amarelo", "cor": "#FFD54F", "valor": "R$ 1,89 por MWh"}, "12": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}},
      "2023": { "1": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "2": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "4": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "5": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "6": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "7": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "8": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "9": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "10": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "11": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "12": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}},
      "2022": { "1": {"nome": "Escassez Hídrica", "cor": "#0d47a1", "valor": "R$ 14,20 por MWh"}, "2": {"nome": "Escassez Hídrica", "cor": "#0d47a1", "valor": "R$ 14,20 por MWh"}, "4": {"nome": "Escassez Hídrica", "cor": "#0d47a1", "valor": "R$ 14,20 por MWh"}, "5": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "6": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "7": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "8": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "9": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "10": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "11": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}, "12": {"nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional"}},
      "2021": { "1": {"nome": "Amarelo", "cor": "#FFD54F", "valor": "R$ 1,34 por MWh"}, "2": {"nome": "Amarelo", "cor": "#FFD54F", "valor": "R$ 1,34 por MWh"}, "4": {"nome": "Amarelo", "cor": "#FFD54F", "valor": "R$ 1,34 por MWh"}, "5": {"nome": "Vermelho 1", "cor": "#E53935", "valor": "R$ 4,17 por MWh"}, "6": {"nome": "Vermelho 2", "cor": "#B71C1C", "valor": "R$ 9,49 por MWh"}, "7": {"nome": "Vermelho 2", "cor": "#B71C1C", "valor": "R$ 9,49 por MWh"}, "8": {"nome": "Vermelho 2", "cor": "#B71C1C", "valor": "R$ 9,49 por MWh"}, "9": {"nome": "Escassez Hídrica", "cor": "#0d47a1", "valor": "R$ 14,20 por MWh"}, "10": {"nome": "Escassez Hídrica", "cor": "#0d47a1", "valor": "R$ 14,20 por MWh"}, "11": {"nome": "Escassez Hídrica", "cor": "#0d47a1", "valor": "R$ 14,20 por MWh"}, "12": {"nome": "Escassez Hídrica", "cor": "#0d47a1", "valor": "R$ 14,20 por MWh"}}
    };

    const anoSelect = document.getElementById('ano');
    Object.keys(db).forEach(ano => {
        let opt = document.createElement('option');
        opt.value = ano; opt.textContent = ano;
        anoSelect.appendChild(opt);
    });

    function updateMonths() {
        const mesSelect = document.getElementById('mes');
        mesSelect.innerHTML = '<option value="">Mês</option>';
        const ano = anoSelect.value;
        if (!ano) return;
        const nomesMes = ["", "Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"];
        Object.keys(db[ano]).forEach(mes => {
            let opt = document.createElement('option');
            opt.value = mes; opt.textContent = nomesMes[mes];
            mesSelect.appendChild(opt);
        });
    }

    function consultar() {
        const ano = document.getElementById('ano').value;
        const mes = document.getElementById('mes').value;
        const res = document.getElementById('result');
        if (!ano || !mes) return alert("Por favor, selecione ano e mês.");
        
        const item = db[ano][mes];
        res.style.display = 'block';
        res.style.background = item.cor + "10";
        res.style.borderLeftColor = item.cor;
        res.innerHTML = `<strong style="color:${item.cor}">${item.nome}</strong><br>Custo Adicional: ${item.valor}`;
    }
</script>
</body>
</html>
