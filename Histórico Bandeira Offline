<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Histórico de Bandeiras | Aubeny</title>
    <style>
        :root { 
            --gradiente: linear-gradient(135deg, #4f46e5, #ec4899, #f97316); 
            --bg: #f8fafc; 
        }
        body { 
            font-family: 'Inter', sans-serif; 
            background: var(--bg); 
            margin: 0; padding: 40px 20px; 
            display: flex; justify-content: center; 
        }
        .container { 
            width: 100%; max-width: 500px; 
            background: white; padding: 30px; border-radius: 24px; 
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }
        /* Topo com o Logo e Gradiente */
        .brand-header { 
            background: var(--gradiente); 
            padding: 20px; border-radius: 16px; 
            text-align: center; margin-bottom: 25px; 
        }
        .logo { width: 80px; height: 80px; border-radius: 50%; border: 3px solid white; }
        
        h1 { font-size: 20px; color: #1e293b; margin-bottom: 5px; }
        .controls { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        select, button { padding: 14px; border-radius: 12px; border: 1.5px solid #e2e8f0; font-size: 15px; }
        button { grid-column: span 2; background: #0f172a; color: white; font-weight: 600; cursor: pointer; transition: 0.3s; }
        button:hover { background: #334155; }
        
        #result { margin-top: 25px; padding: 20px; border-radius: 16px; display: none; border-left: 6px solid #ccc; background: #f1f5f9; }
    </style>
</head>
<body>

<div class="container">
    <!-- Cabeçalho com identidade visual -->
    <div class="brand-header">
        <img src="image_374027.png" alt="Logo Aubeny" class="logo">
    </div>

    <h1>Histórico de Bandeiras</h1>
    <p style="font-size: 13px; color: #64748b;">Consulte o custo extra por MWh de cada período.</p>
    
    <div class="controls">
        <select id="ano" onchange="updateMonths()"><option value="">Ano</option></select>
        <select id="mes"><option value="">Mês</option></select>
        <button onclick="consultar()">Consultar Histórico</button>
    </div>
    <div id="result"></div>
</div>

<script>
    // Base de dados (mantida a mesma estrutura)
    const db = {
      "2026": { "1": { "nome": "Verde", "cor": "#28a745", "valor": "Sem cobrança adicional" }, "5": { "nome": "Amarelo", "cor": "#FFD54F", "valor": "R$ 1,88 por MWh" } },
      "2025": { "6": { "nome": "Vermelho 1", "cor": "#E53935", "valor": "R$ 4,46 por MWh" }, "8": { "nome": "Vermelho 2", "cor": "#B71C1C", "valor": "R$ 7,87 por MWh" } },
      // ... (restante da base de dados)
    };

    // Populando anos
    const anoSelect = document.getElementById('ano');
    Object.keys(db).forEach(ano => {
        let opt = document.createElement('option');
        opt.value = ano; opt.textContent = ano;
        anoSelect.appendChild(opt);
    });

    function updateMonths() {
        const mesSelect = document.getElementById('mes');
        mesSelect.innerHTML = '<option value="">Mês</option>';
        const ano = anoSelect.value;
        if (!ano) return;
        const nomesMes = ["", "Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"];
        Object.keys(db[ano]).forEach(mes => {
            let opt = document.createElement('option');
            opt.value = mes; opt.textContent = nomesMes[mes];
            mesSelect.appendChild(opt);
        });
    }

    function consultar() {
        const ano = document.getElementById('ano').value;
        const mes = document.getElementById('mes').value;
        const res = document.getElementById('result');
        if (!ano || !mes) return alert("Por favor, selecione ano e mês.");
        
        const item = db[ano][mes];
        res.style.display = 'block';
        res.style.background = item.cor + "15";
        res.style.borderLeftColor = item.cor;
        res.innerHTML = `<strong style="color:${item.cor}">${item.nome}</strong><br>Custo Adicional: ${item.valor}`;
    }
</script>
</body>
</html>
