      "2021": {"1":{"n":"Amarelo","c":"#FFD54F","v":"R$ 13,43 por MWh"},"2":{"n":"Amarelo","c":"#FFD54F","v":"R$ 13,43 por MWh"},"3":{"n":"Amarelo","c":"#FFD54F","v":"R$ 13,43 por MWh"},"4":{"n":"Amarelo","c":"#FFD54F","v":"R$ 13,43 por MWh"},"5":{"n":"Vermelho 1","c":"#E53935","v":"R$ 41,69 por MWh"},"6":{"n":"Vermelho 2","c":"#B71C1C","v":"R$ 94,92 por MWh"},"7":{"n":"Vermelho 2","c":"#B71C1C","v":"R$ 94,92 por MWh"},"8":{"n":"Vermelho 2","c":"#B71C1C","v":"R$ 94,92 por MWh"},"9":{"n":"Escassez","c":"#0d47a1","v":"R$ 142,00 por MWh"},"10":{"n":"Escassez","c":"#0d47a1","v":"R$ 142,00 por MWh"},"11":{"n":"Escassez","c":"#0d47a1","v":"R$ 142,00 por MWh"},"12":{"n":"Escassez","c":"#0d47a1","v":"R$ 142,00 por MWh"}}
    };

    let curRate = 0;
    const mesesFull = ["Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"];
    const mesesAbrev = ["Jan", "Fev", "Mar", "Abr", "Mai", "Jun", "Jul", "Ago", "Set", "Out", "Nov", "Dez"];
    const getSvg = (cor, cls) => `<svg class="${cls}" viewBox="0 0 24 24" fill="${cor}"><path d="M14.4 6L14 4H5v17h2v-7h5.6l.4 2h7V6z"/></svg>`;

   
    function updAnoSelect() {
        const selAno = document.getElementById('ano');
        const valAtual = selAno.value;
        selAno.innerHTML = '<option value="">Ano</option>';
        const anos = Object.keys(db).sort((a,b) => b - a); // Mais recentes no topo
        anos.forEach(a => selAno.innerHTML += `<option value="${a}">${a}</option>`);
        if(valAtual && db[valAtual]) selAno.value = valAtual;
    }

    function updMes() {
        const selAno = document.getElementById('ano');
        const selMes = document.getElementById('mes');
        const valAtual = selMes.value;
        selMes.innerHTML = '<option value="">Mês</option>';
        if(selAno.value && db[selAno.value]) {
            Object.keys(db[selAno.value]).forEach(m => selMes.innerHTML += `<option value="${m}">${mesesFull[m-1]}</option>`);
        }
        if(valAtual && db[selAno.value] && db[selAno.value][valAtual]) selMes.value = valAtual;
    }

    function consultar() {
        const a = document.getElementById('ano').value;
        const m = document.getElementById('mes').value;
        const res = document.getElementById('result');
        if (!a || !m) return;
        
        const i = db[a][m];
        res.style.display = 'block'; res.style.background = i.c + "10"; res.style.borderLeftColor = i.c;
        
        let html = `<strong style="color:${i.c}">${i.n}</strong><br>Custo: ${i.v}`;
        if (!i.v.includes("Sem")) {
            curRate = parseFloat(i.v.replace("R$ ", "").replace(" por MWh", "").replace(",", "."));
            html += `
                <div class="calc-box">
                    <p>Consumo mensal (kWh)?</p>
                    <input type="number" id="kwh" class="calc-input" placeholder="Ex: 500" oninput="calc()">
                    <div id="res-calc" class="calc-res"></div>
                    <a href="#" id="btn-share" class="btn-share" target="_blank">📲 Compartilhar no WhatsApp</a>
                </div>`;
        } else curRate = 0;
        res.innerHTML = html;
    }

   function calc() {
        const k = parseFloat(document.getElementById('kwh').value);
        const resBox = document.getElementById('res-calc');
        const shareBtn = document.getElementById('btn-share');
        
        if (k > 0) {
            const valorCalculado = ((k/1000)*curRate);
            const valorFormatado = valorCalculado.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});
            resBox.innerHTML = `Adicional na fatura: ${valorFormatado}`;
            
            const a = document.getElementById('ano').value;
            const m = document.getElementById('mes').value;
            
            // Lógica do tempo verbal (teve / terá)
            const dataAtual = new Date();
            const anoAtual = dataAtual.getFullYear();
            const mesAtual = dataAtual.getMonth() + 1; // getMonth começa no zero
            
            const isPassado = (parseInt(a) < anoAtual) || (parseInt(a) === anoAtual && parseInt(m) < mesAtual);
            const verbo = isPassado ? "teve" : "terá";

            // URL Oficial atualizada na mensagem
            const msg = `Nossa conta de energia ${verbo} um adicional estimado de *${valorFormatado}* em ${mesesFull[m-1]}/${a} devido à Bandeira Tarifária. ⚡\n\nSaiba como se livrar dessa taxa com o Mercado Livre de Energia:\n🔗 aubenenergia.com.br`;
            
            shareBtn.href = `https://api.whatsapp.com/send?text=${encodeURIComponent(msg)}`;
            shareBtn.classList.add('show');
        } else {
            resBox.innerHTML = '';
            shareBtn.classList.remove('show');
        }
    }
    function initTable() {
        const anosTodos = Object.keys(db).map(Number).sort((a,b) => b - a);
        const anos = anosTodos.slice(0, 6).map(String); // Pega apenas os 6 anos mais recentes
        
        // Atualiza cabeçalho dinâmico (Se for 2027, muda sozinho)
        document.getElementById('titulo-visao').innerText = `Visão Geral (${anos[anos.length-1]} - ${anos[0]})`;
        document.getElementById('tabHead').innerHTML = `<th>Mês</th>` + anos.map(a => `<th>${a}</th>`).join('');

        let html = '';
        for (let m = 1; m <= 12; m++) {
            html += `<tr><td>${mesesAbrev[m-1]}</td>` + anos.map(a => {
                const i = db[a] && db[a][m];
                return `<td>${i && i.n !== "nan" ? `<div class="tooltip" data-tip="${i.v}">${getSvg(i.c, 'flag')}</div>` : `<span style="color:#cbd5e1">-</span>`}</td>`;
            }).join('') + `</tr>`;
        }
        document.getElementById('tabBody').innerHTML = html;
        const legData = [["#28a745","Verde"],["#FFD54F","Amarela"],["#E53935","Vermelha 1"],["#B71C1C","Vermelha 2"],["#0d47a1","Escassez"]];
        document.getElementById('legend').innerHTML = legData.map(l => `<div class="leg-item">${getSvg(l[0], 'leg-icon')} ${l[1]}</div>`).join('');
    }

    function toggleAcc() {
        const c = document.getElementById('acc-content'), i = document.getElementById('icon');
        const isClosed = !c.style.maxHeight || c.style.maxHeight === "0px";
        c.style.maxHeight = isClosed ? c.scrollHeight + "px" : "0px";
        i.style.transform = isClosed ? "rotate(180deg)" : "rotate(0deg)";
    }

    // --- MODAL DE CONTATO E WHATSAPP ---
    function abrirContato(e) { if(e) e.preventDefault(); document.getElementById('modal-contato').classList.add('show'); }
    function fecharContato() { document.getElementById('modal-contato').classList.remove('show'); }
    function mascaraTelefone(e) {
        let v = e.target.value.replace(/\D/g, "");
        v = v.replace(/^(\d{2})(\d)/g, "($1) $2");
        v = v.replace(/(\d)(\d{4})$/, "$1-$2");
        e.target.value = v;
    }
    function enviarContato(e) { e.preventDefault(); alert("Solicitação enviada com sucesso! Um especialista da Auben entrará em contato."); fecharContato(); e.target.reset(); }
    window.onclick = function(e) { if (e.target == document.getElementById('modal-contato')) fecharContato(); }

    // --- AUTOMAÇÃO REAL-TIME ANEEL ---
    async function fetchAneelData() {
        try {
            // Consulta o Portal de Dados Abertos Oficial
            const res = await fetch('https://dadosabertos.aneel.gov.br/api/3/action/datastore_search?resource_id=0591b8f6-fe54-437b-b72b-1aa2efd46e42&limit=500');
            const json = await res.json();
            
            if (json.success && json.result && json.result.records) {
                json.result.records.forEach(r => {
                    if (!r.DatCompetencia) return;
                    const partes = r.DatCompetencia.split('-'); // Extrai ano e mês "YYYY-MM"
                    const ano = partes[0];
                    const mes = parseInt(partes[1], 10).toString();
                    
                    let nome = r.NomBandeiraAcionada;
                    let cor = "#cbd5e1";
                    const nL = nome.toLowerCase();
                    
                    // Tratamento Automático das Cores
                    if (nL.includes("verde")) { cor = "#28a745"; nome = "Verde"; }
                    else if (nL.includes("amarela")) { cor = "#FFD54F"; nome = "Amarela"; }
                    else if (nL.includes("p1") || nL.includes("patamar 1")) { cor = "#E53935"; nome = "Vermelha 1"; }
                    else if (nL.includes("vermelha")) { cor = "#B71C1C"; nome = "Vermelha 2"; }
                    else if (nL.includes("escassez")) { cor = "#0d47a1"; nome = "Escassez"; }
                    
                    let vlr = parseFloat(r.VlrAdicionalBandeira.toString().replace(',', '.'));
                    let txtValor = (vlr === 0 || isNaN(vlr)) ? "Sem cobrança adicional" : `R$ ${r.VlrAdicionalBandeira} por MWh`;
                    
                    // Mescla o dado oficial da ANEEL na nossa base interna
                    if (!db[ano]) db[ano] = {};
                    db[ano][mes] = { n: nome, c: cor, v: txtValor };
                });
            }
        } catch (e) { console.log("Usando banco de dados local (Offline Mode)."); }
    }

    // --- INICIALIZADOR GERAL ---
    async function iniciarSite() {
        // 1. Renderiza imediatamente com os dados de backup para não travar a tela
        initTable();
        updAnoSelect();
        
        const dt = new Date(); const aAtual = dt.getFullYear().toString(); const mAtual = (dt.getMonth() + 1).toString();
        const selA = document.getElementById('ano'); const selM = document.getElementById('mes');
        
        if (!selA.value && db[aAtual]) {
            selA.value = aAtual; updMes(); 
            if (db[aAtual][mAtual]) { selM.value = mAtual; consultar(); }
        }

        // 2. Busca na ANEEL em segundo plano
        await fetchAneelData();
        
        // 3. Atualiza tudo com os dados mais frescos e oficiais que chegaram!
        initTable();
        updAnoSelect();
        if (selA.value && selM.value) consultar();
    }

    window.onload = iniciarSite;
</script>
